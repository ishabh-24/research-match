# ResearchMatch — Environment Variables
# Copy this file to .env.local and fill in the real values

# ── Database ──────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/researchmatch"

# ── NextAuth ──────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"   # openssl rand -base64 32

# ── OAuth Providers (optional) ────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Email (Resend) ────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="noreply@researchmatch.io"


